# ===========================
# Infrastructure
# ===========================

# PostgreSQL
PG_USER=toka_user
PG_PASS=toka_secret_pass
PG_DB=toka_main

# MongoDB
MONGO_USER=toka_user
MONGO_PASS=toka_secret_pass

# Redis
REDIS_PASSWORD=toka_redis_pass

# RabbitMQ
RABBIT_USER=toka_rabbit
RABBIT_PASS=toka_rabbit_pass

# Keycloak
KC_ADMIN_USER=admin
KC_ADMIN_PASS=admin_secret_pass
KC_DB_USER=keycloak_user
KC_DB_PASS=keycloak_secret_pass

# ===========================
# Application
# ===========================

# Auth Service
AUTH_SERVICE_PORT=3001
JWT_SECRET=change_me_in_production

# User Service
USER_SERVICE_PORT=3002

# Role Service
ROLE_SERVICE_PORT=3003

# Audit Service
AUDIT_SERVICE_PORT=3004

# BFF Service
BFF_SERVICE_PORT=3005
SESSION_SECRET=change_me_session_secret

# AI Agent Service
AI_SERVICE_PORT=8000

# AI provider options:
# - openai: requires OPENAI_API_KEY
# - ollama: free local development through Ollama on your machine
AI_PROVIDER=ollama
OPENAI_API_KEY=
OPENAI_BASE_URL=
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
LLM_MODEL=qwen2.5:7b
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=768
QDRANT_COLLECTION=toka_documents_ollama

# ===========================
# Frontend
# ===========================
VITE_BFF_URL=http://localhost:3005
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=toka
VITE_KEYCLOAK_CLIENT_ID=toka-frontend
