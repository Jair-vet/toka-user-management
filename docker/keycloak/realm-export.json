{
  "realm": "toka",
  "displayName": "Toka User Management",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "accessTokenLifespan": 900,
  "refreshTokenMaxReuse": 0,
  "revokeRefreshToken": true,
  "clients": [
    {
      "clientId": "toka-frontend",
      "name": "Toka Frontend",
      "description": "React SPA frontend",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost/*",
        "http://localhost:5173/*",
        "http://localhost:3005/bff/auth/callback",
        "http://localhost/auth/callback",
        "http://localhost:3005/auth/callback"
      ],
      "webOrigins": [
        "http://localhost",
        "http://localhost:5173",
        "http://localhost:3005"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      }
    },
    {
      "clientId": "backend-services",
      "name": "Backend Services",
      "description": "Internal backend microservices client",
      "enabled": true,
      "publicClient": false,
      "standardFlowEnabled": false,
      "serviceAccountsEnabled": true,
      "directAccessGrantsEnabled": true,
      "secret": "backend-client-secret",
      "redirectUris": [
        "http://localhost:3001/*"
      ]
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "System administrator"
      },
      {
        "name": "user_manager",
        "description": "User manager"
      },
      {
        "name": "auditor",
        "description": "Audit log viewer"
      },
      {
        "name": "viewer",
        "description": "Basic viewer"
      }
    ]
  },
  "users": [
    {
      "username": "admin@toka.com",
      "email": "admin@toka.com",
      "firstName": "System",
      "lastName": "Admin",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "Admin123!",
          "temporary": false
        }
      ],
      "realmRoles": [
        "admin"
      ]
    }
  ],
  "passwordPolicy": "length(8) and upperCase(1) and digits(1) and specialChars(1)",
  "browserSecurityHeaders": {
    "contentSecurityPolicy": "frame-src 'self'; frame-ancestors 'self'; object-src 'none';",
    "xContentTypeOptions": "nosniff",
    "xFrameOptions": "SAMEORIGIN",
    "xRobotsTag": "none",
    "xXSSProtection": "1; mode=block",
    "strictTransportSecurity": "max-age=31536000; includeSubDomains"
  }
}