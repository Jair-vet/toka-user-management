# Copy to .env and fill in values
# cp .env.example .env

# PostgreSQL
PG_USER=toka_user
PG_PASS=toka_secret_pass

# MongoDB
MONGO_USER=toka_user
MONGO_PASS=toka_secret_pass

# Redis
REDIS_PASSWORD=toka_redis_pass

# RabbitMQ
RABBIT_USER=toka_rabbit
RABBIT_PASS=toka_rabbit_pass

# Keycloak
KC_ADMIN_USER=admin
KC_ADMIN_PASS=admin_secret_pass
KC_DB_USER=keycloak_user
KC_DB_PASS=keycloak_secret_pass
KC_CLIENT_SECRET=backend-client-secret

# Session
SESSION_SECRET=change_me_to_random_32_chars

# AI provider options:
# - openai: requires OPENAI_API_KEY
# - ollama: free local development through Ollama on your machine
AI_PROVIDER=ollama
OPENAI_API_KEY=
OPENAI_BASE_URL=
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
LLM_MODEL=qwen2.5:7b
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=768
QDRANT_COLLECTION=toka_documents_ollama
